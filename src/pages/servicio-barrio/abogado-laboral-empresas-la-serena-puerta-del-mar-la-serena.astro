            <a href="https://wa.me/56912345678?text=Hola%2C%20necesito%20ayuda%20en%20Puerta%20del%20Mar%3A%20Abogado%20Laboral%20para%20Empresas%20en%20La%20Serena" target="_blank" class="block bg-[#C8A951] text-[#1B3A5C] font-bold text-center px-4 py-3 rounded-xl hover:bg-[#D5B652] transition-colors no-underline text-sm mb-4">Consulta Gratis por WhatsApp</a>
            <p class="text-gray-500 text-xs text-center">+56 9 1234 5678</p>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>