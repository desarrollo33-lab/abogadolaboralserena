---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { locations, siteConfig } from '../../data/content';
---

<BaseLayout title="Barrios de Cobertura | Abogado Laboral La Serena" description="Atendemos en todos los barrios de La Serena: Cerro Grande, Las Compañías, San Joaquín, Puerta del Mar, Barrio Germán Río.">
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <h1 class="text-3xl lg:text-4xl font-extrabold text-gray-900">Cobertura en La Serena</h1>
        <p class="mt-4 text-lg text-gray-500 max-w-2xl mx-auto">Atendemos a trabajadores en todos los barrios de La Serena y la región de Coquimbo.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <a href="/barrios/cerro-grande-la-serena" class="block bg-white border border-gray-200 rounded-2xl p-6 no-underline hover:shadow-lg hover:border-[#C8A951]/30 transition-all"><div class="w-12 h-12 bg-[#E8EDF3] rounded-xl flex items-center justify-center mb-4"><svg class="w-6 h-6 text-[#1B3A5C]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg></div><h2 class="font-bold text-lg text-gray-900 mb-2">Cerro Grande</h2><p class="text-gray-500 text-sm">norte · Cerro Grande, Barrio El Litre, Población Japón</p><span class="text-[#1B3A5C] text-sm font-semibold mt-2 block">Ver servicios →</span></a>
        <a href="/barrios/las-companias-la-serena" class="block bg-white border border-gray-200 rounded-2xl p-6 no-underline hover:shadow-lg hover:border-[#C8A951]/30 transition-all"><div class="w-12 h-12 bg-[#E8EDF3] rounded-xl flex items-center justify-center mb-4"><svg class="w-6 h-6 text-[#1B3A5C]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg></div><h2 class="font-bold text-lg text-gray-900 mb-2">Las Compañías</h2><p class="text-gray-500 text-sm">sur · Las Compañías Sur, Las Compañías Norte, Barrio El Romero</p><span class="text-[#1B3A5C] text-sm font-semibold mt-2 block">Ver servicios →</span></a>
        <a href="/barrios/san-joaquin-la-serena" class="block bg-white border border-gray-200 rounded-2xl p-6 no-underline hover:shadow-lg hover:border-[#C8A951]/30 transition-all"><div class="w-12 h-12 bg-[#E8EDF3] rounded-xl flex items-center justify-center mb-4"><svg class="w-6 h-6 text-[#1B3A5C]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg></div><h2 class="font-bold text-lg text-gray-900 mb-2">San Joaquín</h2><p class="text-gray-500 text-sm">norte · San Joaquín, Barrio El Indio, Villa加利福尼亚</p><span class="text-[#1B3A5C] text-sm font-semibold mt-2 block">Ver servicios →</span></a>
        <a href="/barrios/puerta-del-mar-la-serena" class="block bg-white border border-gray-200 rounded-2xl p-6 no-underline hover:shadow-lg hover:border-[#C8A951]/30 transition-all"><div class="w-12 h-12 bg-[#E8EDF3] rounded-xl flex items-center justify-center mb-4"><svg class="w-6 h-6 text-[#1B3A5C]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg></div><h2 class="font-bold text-lg text-gray-900 mb-2">Puerta del Mar</h2><p class="text-gray-500 text-sm">centro · Puerta del Mar, Barrio El Centro, Barrio Obrero</p><span class="text-[#1B3A5C] text-sm font-semibold mt-2 block">Ver servicios →</span></a>
        <a href="/barrios/barrio-german-rio-la-serena" class="block bg-white border border-gray-200 rounded-2xl p-6 no-underline hover:shadow-lg hover:border-[#C8A951]/30 transition-all"><div class="w-12 h-12 bg-[#E8EDF3] rounded-xl flex items-center justify-center mb-4"><svg class="w-6 h-6 text-[#1B3A5C]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg></div><h2 class="font-bold text-lg text-gray-900 mb-2">Barrio Germán Río</h2><p class="text-gray-500 text-sm">centro-oriente · Barrio Germán Río, Villa Jerman, Barrio Colina El Pino</p><span class="text-[#1B3A5C] text-sm font-semibold mt-2 block">Ver servicios →</span></a>
      </div>
    </div>
  </section>
</BaseLayout>