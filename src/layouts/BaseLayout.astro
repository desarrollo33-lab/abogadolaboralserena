            <li><a href="/barrios/cerro-grande-la-serena" class="text-gray-400 text-sm hover:text-white no-underline transition-colors">Cerro Grande</a></li>
            <li><a href="/barrios/las-companias-la-serena" class="text-gray-400 text-sm hover:text-white no-underline transition-colors">Las Compañías</a></li>
            <li><a href="/barrios/san-joaquin-la-serena" class="text-gray-400 text-sm hover:text-white no-underline transition-colors">San Joaquín</a></li>
            <li><a href="/barrios/puerta-del-mar-la-serena" class="text-gray-400 text-sm hover:text-white no-underline transition-colors">Puerta del Mar</a></li>
            <li><a href="/barrios/barrio-german-rio-la-serena" class="text-gray-400 text-sm hover:text-white no-underline transition-colors">Barrio Germán Río</a></li>
          </ul>
        </div>
      </div>
      <div class="border-t border-gray-700 mt-10 pt-6 text-center text-gray-500 text-xs">
        <p>&copy; 2026 Estudio Jurídico Laboral La Serena SPA. Todos los derechos reservados.</p>
      </div>
    </div>
  </footer>
