          <p class="text-gray-400 text-sm">+56 9 1234 5678 | info@abogadolaboralserena.cl</p>
          <p class="text-gray-400 text-sm mt-1">Mo-Fr 09:00-19:00, Sa 10:00-14:00</p>
        </div>
        <div>
